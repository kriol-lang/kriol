fn ola(textu nomi, bool naKriolu) {
  si naKriolu {
    mostran(f"Olá {nomi}, ami nta programa na Kriol!");
  } sinon {
    mostran(f"Hello {nomi}, I program in Kriol!");
  }
}

fn inisiu() {
  // Toma nomi atravez di entrada
  textu nomi = toma('Nomi: ');

  // Tchoma funson ola
  ola(nomi, sin);
  ola(nomi, nau);
}