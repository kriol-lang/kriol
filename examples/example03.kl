fn dizenhaLinha(num tamanhu, bool dizenhaLinhaNaFin) {
    dipoz num i;

    pa i = 0 ; i < tamanhu ; i += 1 {
        mostra("-");
    }

    si dizenhaLinhaNaFin {
        mostra("\n");
    }
}

fn mostraMensagem() {
    num i = 1;

    nkuantu i < 10 {
        dizenhaLinha(i, sin);
        i += 1;
    }

    dizenhaLinha(i, nau);
    mostran("  Oi, Kriol!");

    pa i = i - 1 ; i > 0 ; i = i - 1 {
        dizenhaLinha(i, sin);
    }
}

fn inisiu() {
    mostraMensagem();
}
